	  <PackageReadmeFile>README.nuget.md</PackageReadmeFile>
	  <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	  <LangVersion>11</LangVersion>
	  <!--<PackageReadmeFile>README.nuget.md</PackageReadmeFile>-->
